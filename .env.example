DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DB_ENGINE=django.db.backends.postgresql
DB_NAME=saas_futebol
DB_USER=saas_futebol
DB_PASSWORD=saas_futebol
DB_HOST=db
DB_PORT=5432

# Evidências privadas (10 MB por padrão).
DJANGO_MEDIA_ROOT=/app/var/media
EVIDENCE_MAX_UPLOAD_SIZE=10485760
EVIDENCE_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg
EVIDENCE_ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg,image/pjpeg

# Produção — use DJANGO_SETTINGS_MODULE=config.settings_production.
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SESSION_COOKIE_SECURE=1
# DJANGO_CSRF_COOKIE_SECURE=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
# DJANGO_SECURE_HSTS_PRELOAD=1

# IA — credenciais dos providers (opcionais; só enviadas a hosts permitidos).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_API_KEY=
# AI_PROVIDER_API_KEY=
# Hosts extras permitidos para api_base_url de providers (ex.: proxy/endpoint
# próprio confiável). Separe por vírgula. Sem isto, só os hosts oficiais valem.
# AI_PROVIDER_ALLOWED_HOSTS=
# Fonte esportiva operacional (football-data.org)
FOOTBALL_DATA_ORG_API_KEY=
